---
import { img } from '@/config/site';
const { style } = Astro.props as { style?: string };
---
<footer style={style}>
  <div class="footer-logo">
    <img
      src={img('brand/logo.png')}
      alt="Shizuoka ShutterBugs ロゴ"
      width="36"
      height="36"
      style="width:36px; height:36px; vertical-align:middle; margin-right:10px; border-radius:50%;"
    /><span class="logo-s">S</span>hizuoka <span class="logo-s2">S</span>hutter<span class="logo-b">B</span>ugs
  </div>
  <div class="footer-copy">© 2025 Shizuoka ShutterBugs. All rights reserved.</div>
</footer>
