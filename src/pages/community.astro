---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import { img } from '@/config/site';

const title = 'COMMUNITY｜Shizuoka ShutterBugs（静岡の写真コミュニティ）';
const description =
  '静岡で写真を撮る人たちが集まり、フォトウォークや写真集会・オンライン交流で写真を楽しむコミュニティ「Shizuoka ShutterBugs」。メンバー中心で活動を企画しています。';

const features = [
  {
    bg: 'community/cm-01.webp',
    heading: 'メンバー中心で企画・活動',
    body: 'SSBの活動は、メンバーひとりひとりがやりたいことを提案し、みんなで作り上げていきます。どなたでも発言していただいて構いません。メンバーのたくさんのアイデアが、そのままSSBの活動と足跡になります。',
    link: false,
  },
  {
    bg: 'community/cm-02.webp',
    heading: 'オープンチャットで交流',
    body: '交流はLINEオープンチャットを使用しています。エリア別でお誘いをしたり、参加者で会議室に集まって話し合ったり、目的別で参加することができます。写真の話題はもちろん、ちょっとした雑談まで気兼ねなくどうぞ。',
    link: true,
  },
  {
    bg: 'community/cm-03.webp',
    heading: 'SSB限定イベント',
    body: 'SSB内フォトウォークやメンバー企画はもちろんのこと、企業・組織様とのコラボ企画等にも参加できます。SSBメンバーだからこそ参加・体験できることが集まっています。',
    link: false,
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="page active" id="page-community">
    <div class="page-header fade-up">
      <p class="section-label">Community</p>
      <h1>COMMUNITY</h1>
    </div>

    <div class="about-section fade-up">
      <div class="about-inner">
        <p class="section-label">About</p>
        <h2>Shizuoka<br /><em>ShutterBugsとは</em></h2>
        <p>
          静岡で写真を撮る人たちが集まり、フォトウォークや写真集会、オンライン交流などを通して写真を楽しみ追求するコミュニティです。
          メンバーで活動を企画したり、写真を通して新たな活動・価値を創り上げていく場所でもあります。
        </p>
        <p>
          また、静岡を盛り上げたり、写真文化を深めたりするための取り組みも行なっています。（詳細はWORKSをご覧ください）
        </p>
      </div>
    </div>

    <div class="features-section fade-up">
      <div class="features-inner">
        <p class="section-label" style="justify-content:center;">Why SSB?</p>
        <h2 class="features-title">Shizuoka ShutterBugsの<em>魅力</em></h2>
        <div class="features-grid">
          {
            features.map((f) => (
              <div
                class="feature-card feature-card--photo"
                style="padding:0; overflow:hidden; position:relative; background:#f5f0e8; display:flex; flex-direction:column;"
              >
                <div
                  style={`width:100%; height:200px; background-image:url('${img(f.bg)}'); background-size:cover; background-position:center; flex-shrink:0;`}
                />
                <div style="width:100%; height:60px; background:linear-gradient(to bottom, transparent, #f5f0e8); margin-top:-60px; flex-shrink:0;" />
                <div style="padding:0 1.8rem 2rem; background:#f5f0e8;">
                  <div class="feature-icon" style="color:var(--accent);">
                    ✦
                  </div>
                  <h3 class="feature-heading" style="color:var(--ink);">
                    {f.heading}
                  </h3>
                  <p class="feature-desc" style="color:var(--bark);">
                    {f.body}
                  </p>
                  {f.link && (
                    <a href="/openchat" class="feature-link">
                      詳細はこちら <span class="arrow">→</span>
                    </a>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>
