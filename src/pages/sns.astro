---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Footer from '@/components/Footer.astro';
import { snsLinks } from '@/data/sns';

const title = 'SNS・各種リンク｜Shizuoka ShutterBugs（静岡の写真コミュニティ）';
const description =
  '静岡の写真コミュニティ「Shizuoka ShutterBugs」の公式SNS一覧。Instagram・X・note・YouTubeで活動情報を発信中。';

const faIcon: Record<string, string> = {
  instagram: 'fa-brands fa-instagram',
  x: 'fa-brands fa-x-twitter',
  youtube: 'fa-brands fa-youtube',
};
---

<BaseLayout title={title} description={description}>
  <div class="page active" id="page-sns">
    <div class="page-header fade-up">
      <p class="section-label">SNS</p>
      <h1>SNS<em>・各種リンク</em></h1>
    </div>

    <div class="sns-page-inner fade-up">
      <div class="sns-cards-grid">
        {
          snsLinks.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class={`sns-big-card ${s.kind}`}>
              <div class="sns-icon-wrap">
                {s.kind === 'note' ? (
                  <svg width="22" height="22" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="100" height="100" rx="20" fill="none" />
                    <path
                      d="M20 75V30C20 24.477 24.477 20 30 20H55L80 45V75C80 80.523 75.523 85 70 85H30C24.477 85 20 80.523 20 75Z"
                      stroke="white"
                      stroke-width="7"
                      fill="none"
                    />
                    <path
                      d="M55 20V45H80"
                      stroke="white"
                      stroke-width="7"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                    <line x1="35" y1="58" x2="65" y2="58" stroke="white" stroke-width="6" stroke-linecap="round" />
                    <line x1="35" y1="70" x2="55" y2="70" stroke="white" stroke-width="6" stroke-linecap="round" />
                  </svg>
                ) : (
                  <i class={faIcon[s.kind]} />
                )}
              </div>
              <div>
                <div class="sns-card-name">{s.name}</div>
                <div class="sns-card-handle">{s.handle}</div>
                {s.desc && (
                  <ul class="sns-card-desc">
                    {s.desc.map((d) => (
                      <li>{d}</li>
                    ))}
                  </ul>
                )}
              </div>
              <div class="sns-card-arrow">開く →</div>
            </a>
          ))
        }
      </div>
    </div>

    <Footer style="margin-top:4rem;" />
  </div>
</BaseLayout>
